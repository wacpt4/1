{ "sentence": "The issue remains **obscure** to the public.", "answer": "opaque" },
{ "sentence": "Economic growth may **yield** long-term benefits.", "answer": "engender" }
];

const PAGE_SIZE = 6; // 固定一页 6 题
const FAV_KEY = "IELTS_FAV_001";

let questions = [...ALL_QUESTIONS];
let currentPage = 0;
let selectedWord = null;

/* ==================== 深色/浅色模式切换 ==================== */
const themeBtn = document.getElementById("themeToggleBtn");
function initTheme() {
  const savedTheme = localStorage.getItem("IELTS_THEME") || "light";
  document.documentElement.setAttribute("data-theme", savedTheme);
  themeBtn.textContent = savedTheme === "dark" ? "☀️" : "🌙";
}

themeBtn.onclick = () => {
  const current = document.documentElement.getAttribute("data-theme");
  const next = current === "dark" ? "light" : "dark";
  document.documentElement.setAttribute("data-theme", next);
  localStorage.setItem("IELTS_THEME", next);
  themeBtn.textContent = next === "dark" ? "☀️" : "🌙";
};

/* ==================== LocalStorage 交互 ==================== */
function loadFavs(){ return JSON.parse(localStorage.getItem(FAV_KEY) || "[]"); }
function saveFav(q){
  const favs = loadFavs();
  if(!favs.some(f=>f.sentence===q.sentence)){
    favs.push(q);
    localStorage.setItem(FAV_KEY, JSON.stringify(favs));
  }
}
function removeFav(q){
  let favs = loadFavs().filter(f=>f.sentence!==q.sentence);
  localStorage.setItem(FAV_KEY, JSON.stringify(favs));
}
function isFav(q){ return loadFavs().some(f=>f.sentence===q.sentence); }

/* ==================== 主渲染逻辑 ==================== */
function renderPage() {
  selectedWord = null;
  const container = document.getElementById("quiz-container");
  const bank = document.getElementById("wordBank");
  container.innerHTML = "";
  bank.innerHTML = "";
  document.getElementById("result-toast").textContent = "";

  const totalPages = Math.ceil(questions.length / PAGE_SIZE) || 1;
  if(currentPage >= totalPages) currentPage = totalPages - 1;

  const pageQs = questions.slice(currentPage * PAGE_SIZE, currentPage * PAGE_SIZE + PAGE_SIZE);

  // 1. 渲染卡片 (一页6题)
  pageQs.forEach((q, idx)=>{
    const card = document.createElement("div");
    card.className = "question-card";

    const favClass = isFav(q) ? "star-btn active" : "star-btn";
    const html = q.sentence.replace(/\*\*(.+?)\*\*/g,
      `<span class="target-word" data-answer="${q.answer}" data-orig="$1">$1</span>`);

    card.innerHTML = `
      <div class="question-row">
        <div class="sentence">${html}</div>
        <div class="${favClass}" title="收藏本题">⭐</div>
      </div>
    `;
    container.appendChild(card);
  });

  // 2. 渲染词库
  const currentAnswers = pageQs.map(q => q.answer).sort(() => Math.random() - 0.5);
  currentAnswers.forEach(ans => createWordElement(ans));

  // 3. 槽位点击逻辑
  document.querySelectorAll(".target-word").forEach(t => {
    t.addEventListener("click", () => {
      // 撤销退回词库
      if(t.dataset.filled){
        createWordElement(t.dataset.filled);
        delete t.dataset.filled;
        t.textContent = t.dataset.orig;
        return;
      }
      // 填入选中词
      if(selectedWord){
        const wordText = selectedWord.textContent;
        t.dataset.filled = wordText;
        t.textContent = wordText;
        speak(wordText);
        selectedWord.remove();
        selectedWord = null;
      } else {
        speak(t.textContent);
      }
    });
  });

  // 4. 收藏图标逻辑
  document.querySelectorAll(".star-btn").forEach((star, idx) => {
    const q = pageQs[idx];
    star.onclick = () => {
      if(isFav(q)){
        removeFav(q);
        star.classList.remove("active");
      } else {
        saveFav(q);
        star.classList.add("active");
      }
    };
  });

  document.getElementById("pageInfo").textContent = `${currentPage + 1} / ${totalPages} 页`;
  document.getElementById("jumpInput").value = currentPage + 1;
}

function createWordElement(text) {
  const bank = document.getElementById("wordBank");
  const w = document.createElement("div");
  w.className = "word";
  w.textContent = text;

  w.addEventListener("click", () => {
    speak(text);
    if(selectedWord === w){
      w.classList.remove("selected");
      selectedWord = null;
    } else {
      if(selectedWord) selectedWord.classList.remove("selected");
      w.classList.add("selected");
      selectedWord = w;
    }
  });

  bank.appendChild(w);
}

/* ==================== 提交验证与反馈 ==================== */
document.getElementById("submitBtn").onclick = () => {
  let score = 0;
  let hasCorrect = false;
  let hasError = false;

  document.querySelectorAll(".question-card").forEach((card, idx) => {
    const target = card.querySelector(".target-word");
    const correct = target.dataset.answer;
    const user = target.dataset.filled;

    target.classList.remove("correct", "error");
    card.querySelectorAll(".answer-row").forEach(e => e.remove());

    const row = document.createElement("div");
    row.className = "answer-row";

    if(user === correct) {
      target.classList.add("correct");
      triggerConfetti(target); // 粒子烟花动画
      score++;
      hasCorrect = true;
    } else {
      target.classList.add("error");
      hasError = true;
    }

    row.innerHTML = `<span class="correct-answer">✓ ${correct}</span>` +
                    (user !== correct && user ? `<span class="user-answer">✕ ${user}</span>` : "");
    card.appendChild(row);
  });

  // 音效触发
  if(hasCorrect && !hasError) {
    sfx.playCorrect();
  } else if(hasError) {
    sfx.playError();
  } else if(hasCorrect) {
    sfx.playCorrect();
  }

  document.getElementById("result-toast").textContent =
    `🎉 本页得分：${score} / ${document.querySelectorAll(".target-word").length}`;
};

/* ==================== 翻页与跳页逻辑 ==================== */
document.getElementById("nextBtn").onclick = () => {
  const totalPages = Math.ceil(questions.length / PAGE_SIZE);
  if(currentPage + 1 < totalPages){
    currentPage++;
    renderPage();
  }
};

document.getElementById("prevBtn").onclick = () => {
  if(currentPage > 0){
    currentPage--;
    renderPage();
  }
};

/* ⚡ 跳页按键 */
document.getElementById("jumpBtn").onclick = handleJump;
document.getElementById("jumpInput").onkeyup = (e) => {
  if (e.key === "Enter") handleJump();
};

function handleJump() {
  const input = document.getElementById("jumpInput");
  let targetPage = parseInt(input.value) - 1;
  const maxPage = Math.ceil(questions.length / PAGE_SIZE) - 1;

  if (isNaN(targetPage) || targetPage < 0 || targetPage > maxPage) {
    alert(`页码超出范围！请输入 1 到 ${maxPage + 1} 之间的数字。`);
    return;
  }
  currentPage = targetPage;
  renderPage();
}

/* ==================== 模式切换 ==================== */
document.getElementById("favModeBtn").onclick = () => {
  const favs = loadFavs();
  if(!favs.length){ alert("⭐ 暂无收藏单词！"); return; }
  questions = favs;
  currentPage = 0;
  document.getElementById("modeTip").textContent = "💎 收藏夹";
  renderPage();
};

document.getElementById("allModeBtn").onclick = () => {
  questions = [...ALL_QUESTIONS];
  currentPage = 0;
  document.getElementById("modeTip").textContent = "⚔️ 练习模式";
  renderPage();
};

// 初始化
initTheme();
renderPage();
</script>
